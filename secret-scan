    (r'aws_secret_access_key\s*[=:]\s*["\']?[A-Za-z0-9/+=]{40}', 'AWS Secret Key', 'high'),

    # Generic API Keys
    (r'(?i)api[_-]?key\s*[=:]\s*["\']?[A-Za-z0-9_\-]{20,}', 'Generic API Key', 'medium'),
    (r'(?i)apikey\s*[=:]\s*["\']?[A-Za-z0-9_\-]{20,}', 'API Key', 'medium'),

    # Private Keys
    (r'-----BEGIN (RSA |DSA |EC |OPENSSH |PGP )?PRIVATE KEY-----', 'Private Key', 'critical'),
    (r'-----BEGIN CERTIFICATE-----', 'Certificate', 'high'),

