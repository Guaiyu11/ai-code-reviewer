    (r'(?i)^(export\s+)?(AWS_|AZURE_|GOOGLE_|STRIPE_|SENTRY_|SLACK_|HEROKU_)[A-Z_]+=[\'"]?.+', 'Env Variable Secret', 'high'),

    # Generic high-entropy strings that look like keys/tokens
    (r'["\'][A-Fa-f0-9]{32}["\']', 'Potential 32-char Hex Secret', 'low'),
    (r'["\'][A-Za-z0-9+/]{40}==?["\']', 'Potential Base64 Secret', 'low'),

    # Google API Key
    (r'AIza[0-9A-Za-z_-]{35}', 'Google API Key', 'high'),
