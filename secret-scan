    (r'Host\s+[^\n]+', 'SSH Host Config', 'low'),
]

# Files/dirs to skip
DEFAULT_EXCLUDE_PATTERNS = {
    '.git', '.svn', '.hg',
    'node_modules', 'bower_components', 'vendor',
    '__pycache__', '.pytest_cache', '.mypy_cache',
    'dist', 'build', 'coverage', '.tox',
    '.DS_Store', 'Thumbs.db',
    'package-lock.json', 'yarn.lock', 'poetry.lock',
    '.env.example', '.env.template',
    'secrets.yaml', 'secrets.json',
    '.terraform.lock.hcl',
}

# File extensions to scan
SCANNABLE_EXTENSIONS = {
    '.py', '.js', '.ts', '.jsx', '.tsx', '.go', '.java', '.rb', '.php',
    '.cs', '.cpp', '.c', '.h', '.swift', '.kt', '.scala', '.rs',
    '.sh', '.bash', '.zsh', '.fish', '.ps1',
    '.json', '.yaml', '.yml', '.toml', '.ini', '.cfg', '.conf',
    '.env', '.properties', '.gradle', '.xml',
    '.md', '.txt', '.rst', '.adoc',
    '.sql', '.graphql', '.proto',
    '.tf', '.tfvars', '.jsonnet',
    'Dockerfile', 'docker-compose.yml', 'Makefile',
    '.gitignore', '.dockerignore',
}


@dataclass
class SecretFinding:
    """Represents a found secret."""
    file_path: str
    line_number: int
    line_content: str
    pattern_name: str
    severity: str
    match: str


class SecretScanner:
    def __init__(self, path: str, recursive: bool = True, use_gitignore: bool = True):
        self.path = Path(path)
        self.recursive = recursive
        self.use_gitignore = use_gitignore
        self.findings: List[SecretFinding] = []
        self.scanned_files = 0
        self.skipped_files = 0

    def should_exclude_path(self, path: Path) -> bool:
        """Check if path should be excluded."""
        parts = path.parts
        for part in parts:
            if part in DEFAULT_EXCLUDE_PATTERNS:
                return True
            if part.startswith('.') and part not in {'.env'}:
                return True
        return False

    def is_scannable_file(self, path: Path) -> bool:
        """Check if file should be scanned."""
        if path.name.startswith('.'):
            return path.name in {'.env', '.env.local', '.env.development', '.env.production'}
        return path.suffix in SCANNABLE_EXTENSIONS or path.name in {
            'Makefile', 'Dockerfile', 'docker-compose.yml', 'docker-compose.yaml',
            'Vagrantfile', 'Procfile', 'Rakefile',
        }

    def scan_file(self, file_path: Path) -> None:
        """Scan a single file for secrets."""
        try:
            self.scanned_files += 1
            with open(file_path, 'r', encoding='utf-8', errors='replace') as f:
                for line_num, line in enumerate(f, 1):
                    # Skip lines that are comments
                    stripped = line.strip()
                    if stripped.startswith('#') or stripped.startswith('//') or stripped.startswith('/*'):
                        continue

                    for pattern, name, severity in SECRET_PATTERNS:
                        if re.search(pattern, line):
                            # Mask the match for display
                            match = re.search(pattern, line)
                            if match:
                                match_str = match.group()
                                masked = match_str[:4] + '*' * (len(match_str) - 8) + match_str[-4:] if len(match_str) > 8 else '****'
                                finding = SecretFinding(
                                    file_path=str(file_path),
                                    line_number=line_num,
                                    line_content=line.strip(),
                                    pattern_name=name,
                                    severity=severity,
                                    match=masked
                                )
                                self.findings.append(finding)
        except Exception as e:
            pass  # Skip files we can't read

    def scan(self) -> None:
        """Scan the path for secrets."""
        if self.path.is_file():
            if not self.should_exclude_path(self.path):
                self.scan_file(self.path)
        elif self.path.is_dir():
            if self.recursive:
                for root, dirs, files in os.walk(self.path):
                    # Filter out excluded directories
                    dirs[:] = [d for d in dirs if d not in DEFAULT_EXCLUDE_PATTERNS and not d.startswith('.')]
                    for file in files:
                        file_path = Path(root) / file
                        if self.is_scannable_file(file_path):
                            self.scan_file(file_path)
            else:
                for file in self.path.iterdir():
                    if file.is_file() and self.is_scannable_file(file):
                        self.scan_file(file)

    def print_results(self, output_format: str = 'text') -> None:
        """Print scan results."""
        severity_emoji = {
            'critical': '🔴',
            'high': '🟠',
            'medium': '🟡',
            'low': '🔵',
        }

        if not self.findings:
            print("✅ No secrets found!")
            print(f"   Scanned {self.scanned_files} files.")
            return

        if output_format == 'json':
            import json
            output = [{
                'file': f.file_path,
                'line': f.line_number,
                'type': f.pattern_name,
                'severity': f.severity,
                'masked': f.match,
            } for f in self.findings]
            print(json.dumps(output, indent=2))
        else:
            print(f"\n⚠️  Found {len(self.findings)} potential secret(s):\n")
            for finding in self.findings:
                emoji = severity_emoji.get(finding.severity, '⚪')
                print(f"{emoji} [{finding.severity.upper()}] {finding.pattern_name}")
                print(f"   📄 {finding.file_path}:{finding.line_number}")
                print(f"   💡 {finding.line_content[:100]}")
                print(f"   🔑 Match: {finding.match}")
                print()

            print(f"📊 Summary: Scanned {self.scanned_files} files, found {len(self.findings)} secret(s).")
            by_severity = {}
            for f in self.findings:
                by_severity[f.severity] = by_severity.get(f.severity, 0) + 1
            print("   By severity: " + ", ".join(f"{k}: {v}" for k, v in sorted(by_severity.items(), key=lambda x: ['critical', 'high', 'medium', 'low'].index(x[0]))))


def main():
    parser = argparse.ArgumentParser(
        description="Scan files and directories for accidentally committed secrets.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  secret-scan .
  secret-scan ./src --recursive
  secret-scan config.yaml --output json
  secret-scan . --no-gitignore
  secret-scan . --output json > secrets.json
        """
    )
    parser.add_argument('path', nargs='?', default='.', help='Path to scan (file or directory)')
    parser.add_argument('-r', '--recursive', action='store_true', default=True, help='Recursive scan (default: True)')
    parser.add_argument('--no-recursive', dest='recursive', action='store_false', help='Disable recursive scan')
    parser.add_argument('--output', '-o', choices=['text', 'json'], default='text', help='Output format')
    parser.add_argument('--no-gitignore', dest='gitignore', action='store_false', default=True, help='Respect .gitignore patterns')

    args = parser.parse_args()

    scanner = SecretScanner(args.path, recursive=args.recursive, use_gitignore=args.gitignore)
    scanner.scan()
    scanner.print_results(args.output)


if __name__ == '__main__':
    main()
