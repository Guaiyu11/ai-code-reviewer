#!/usr/bin/env python3
"""
Secret Scan - Scan files and directories for accidentally committed secrets.
Detects API keys, passwords, tokens, private keys, and other sensitive data.
Usage: secret-scan <path> [--recursive] [--no-gitignore] [--output format]
"""

import argparse
import os
import re
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import List, Optional, Set


# Secret patterns with regex and descriptions
SECRET_PATTERNS = [
    # AWS Keys
    (r'AKIA[0-9A-Z]{16}', 'AWS Access Key ID', 'high'),
