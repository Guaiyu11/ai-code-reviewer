    (r'ghp_[A-Za-z0-9]{36}', 'GitHub Personal Access Token', 'critical'),
    (r'github_pat_[A-Za-z0-9_]{22,}', 'GitHub PAT', 'critical'),
    (r'gho_[A-Za-z0-9]{36}', 'GitHub OAuth', 'critical'),
    (r'ghu_[A-Za-z0-9]{36}', 'GitHub User Access Token', 'critical'),
    (r'ghs_[A-Za-z0-9]{36}', 'GitHub Server Access Token', 'critical'),
    (r'ghr_[A-Za-z0-9]{36}', 'GitHub Refresh Token', 'critical'),

    # Slack Tokens
    (r'xox[baprs]-[0-9]{10,13}-[0-9]{10,13}[a-zA-Z0-9-]*', 'Slack Token', 'high'),

    # Discord Tokens
    (r'[A-Za-z0-9]{24}\.[A-Za-z0-9]{6}\.[A-Za-z0-9_-]{27,}', 'Discord Token', 'critical'),

    # Stripe Keys
    (r'sk_live_[0-9a-zA-Z]{24,}', 'Stripe Live Secret Key', 'critical'),
    (r'pk_live_[0-9a-zA-Z]{24,}', 'Stripe Live Public Key', 'medium'),
    (r'sk_test_[0-9a-zA-Z]{24,}', 'Stripe Test Secret Key', 'high'),
    (r'rk_test_[0-9a-zA-Z]{24,}', 'Stripe Test Restricted Key', 'medium'),

    # JWT Tokens (base64 encoded, not perfect but useful)
    (r'eyJ[A-Za-z0-9_-]*\.eyJ[A-Za-z0-9_-]*\.[A-Za-z0-9_-]*', 'JWT Token', 'medium'),

    # Generic Secrets
    (r'(?i)(secret|password|passwd|pwd|token|auth)[_-]?token\s*[=:]\s*["\'][A-Za-z0-9_\-]{8,}', 'Secret Token', 'high'),
    (r'(?i)bearer\s+[A-Za-z0-9_\-\.]+', 'Bearer Token', 'medium'),
    (r'(?i)basic\s+[A-Za-z0-9_\-]+=*', 'Basic Auth', 'medium'),

    # Database Connection Strings
    (r'(?i)mongodb(\+srv)?://[A-Za-z0-9_\-:@/]+', 'MongoDB Connection', 'high'),
    (r'(?i)mysql://[A-Za-z0-9_\-:@/]+', 'MySQL Connection', 'high'),
    (r'(?i)postgres(ql)?://[A-Za-z0-9_\-:@/]+', 'PostgreSQL Connection', 'high'),
