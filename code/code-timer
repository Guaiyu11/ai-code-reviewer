#!/usr/bin/env python3
"""
Code Timer - Measure execution time of any shell command with formatted output.
Usage: code-timer <command> [args...]
"""

import argparse
import shlex
import subprocess
import sys
import time
from datetime import timedelta


def format_duration(seconds: float) -> str:
    """Format duration in human-readable format."""
    if seconds < 1:
        return f"{seconds*1000:.2f}ms"
    elif seconds < 60:
        return f"{seconds:.3f}s"
    else:
        td = timedelta(seconds=int(seconds))
        if seconds < 3600:
            return f"{int(seconds//60)}m {int(seconds%60)}s"
        else:
            hours = int(seconds // 3600)
            minutes = int((seconds % 3600) // 60)
            secs = int(seconds % 60)
            return f"{hours}h {minutes}m {secs}s"


def format_bytes(size: int) -> str:
    """Format bytes in human-readable format."""
    for unit in ['B', 'KB', 'MB', 'GB']:
        if size < 1024:
            return f"{size:.1f}{unit}"
        size /= 1024
    return f"{size:.1f}TB"


def run_timed_command(cmd: str) -> tuple[int, float, str, str]:
    """Run command and return (exit_code, duration, stdout, stderr)."""
    start = time.perf_counter()
    try:
        result = subprocess.run(
            cmd,
            shell=True,
            capture_output=True,
            text=True,
            timeout=600
        )
        exit_code = result.returncode
        stdout = result.stdout
        stderr = result.stderr
    except subprocess.TimeoutExpired:
        return (-1, time.perf_counter() - start, "", "Command timed out after 600s")
    except Exception as e:
        return (-1, time.perf_counter() - start, "", str(e))
    
    duration = time.perf_counter() - start
    return exit_code, duration, stdout, stderr


def print_result(cmd: str, duration: float, exit_code: int, stdout: str, stderr: str, 
                 show_output: bool = False, show_stats: bool = True):
    """Print formatted results."""
    # Header
    print("\n" + "="*60)
    print("⏱️  CODE TIMER RESULTS")
    print("="*60)
    
    # Command
    print(f"\n📎 Command: {cmd}")
    
    # Duration (prominent)
    print(f"\n⏱️  Duration: {format_duration(duration)}")
    
    # Exit status
    if exit_code == 0:
        print("✅ Exit: 0 (success)")
    else:
        print(f"❌ Exit: {exit_code}")
    
    # Stats
    if show_stats:
        print("\n" + "-"*40)
        print("📊 Statistics")
        print("-"*40)
        print(f"  Duration (seconds): {duration:.4f}s")
        print(f"  Duration (ms):        {duration*1000:.2f}ms")
        if stdout:
            lines = stdout.strip().split('\n') if stdout.strip() else []
            print(f"  Stdout lines:        {len(lines)}")
            print(f"  Stdout chars:        {len(stdout)}")
        if stderr:
            print(f"  Stderr chars:        {len(stderr)}")
    
    # Output
    if show_output:
        if stdout:
            print("\n" + "-"*40)
            print("📄 STDOUT")
            print("-"*40)
            print(stdout[:5000] if len(stdout) > 5000 else stdout)
        if stderr:
            print("\n" + "-"*40)
            print("⚠️  STDERR")
            print("-"*40)
            print(stderr[:2000] if len(stderr) > 2000 else stderr)
    
    print("\n" + "="*60)


def main():
    parser = argparse.ArgumentParser(
        description="Measure execution time of any shell command.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  code-timer python script.py
  code-timer "find . -name '*.py' | wc -l"
  code-timer --output npm run build
  code-timer --stats sleep 2
        """
    )
    parser.add_argument('command', nargs='+', help='Command to time (use quotes for pipes/etc)')
    parser.add_argument('-o', '--output', action='store_true', help='Show command output')
    parser.add_argument('-s', '--stats', action='store_true', help='Show detailed statistics')
    parser.add_argument('-q', '--quiet', action='store_true', help='Only show duration')
    parser.add_argument('-f', '--format', choices=['simple', 'json'], default='simple',
                        help='Output format')
    
    args = parser.parse_args()
    
    if not args.command:
        parser.print_help()
        sys.exit(1)
    
    # Reconstruct command string
    cmd = ' '.join(args.command)
    
    # Quick mode for single commands
    if args.quiet:
        start = time.perf_counter()
        result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
        duration = time.perf_counter() - start
        print(format_duration(duration))
        sys.exit(result.returncode)
    
    # Full timing mode
    show_output = args.output or args.stats
    exit_code, duration, stdout, stderr = run_timed_command(cmd)
    print_result(cmd, duration, exit_code, stdout, stderr, show_output=show_output, 
                 show_stats=args.stats or not args.output)
    
    sys.exit(exit_code if exit_code != -1 else 1)


if __name__ == '__main__':
    main()
