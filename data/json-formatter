#!/usr/bin/env python3
"""
JSON Formatter - Pretty-prints and validates JSON files with color output.
Usage: json-formatter <file> [--minify] [--sort-keys] [--validate]
"""

import argparse
import json
import sys
from pathlib import Path
from typing import Any, Optional


# ANSI color codes
COLORS = {
    "reset": "\033[0m",
    "bold": "\033[1m",
    "dim": "\033[2m",
    "red": "\033[91m",
    "green": "\033[92m",
    "yellow": "\033[93m",
    "blue": "\033[94m",
    "magenta": "\033[95m",
    "cyan": "\033[96m",
    "white": "\033[97m",
}


def colorize(text: str, color: str) -> str:
    """Apply color to text."""
    return f"{COLORS.get(color, '')}{text}{COLORS['reset']}"


def colorize_json_value(value: Any, indent: int = 0) -> str:
    """Recursively colorize JSON values."""
    if isinstance(value, bool):
        return colorize(str(value).lower(), "yellow")
    elif isinstance(value, (int, float)):
        return colorize(str(value), "cyan")
    elif value is None:
        return colorize("null", "magenta")
    elif isinstance(value, str):
        # Check for common patterns to color differently
        if value.startswith("http://") or value.startswith("https://"):
            return colorize(f'"{value}"', "blue")
        return colorize(f'"{value}"', "green")
    elif isinstance(value, dict):
        return colorize_dict(value, indent)
    elif isinstance(value, list):
        return colorize_list(value, indent)
    return str(value)


def colorize_dict(obj: dict, indent: int = 0) -> str:
    """Colorize a JSON object."""
    if not obj:
        return "{}"
    prefix = " " * indent
    items = []
    for k, v in obj.items():
        key_str = colorize(f'"{k}"', "magenta")
        val_str = colorize_json_value(v, indent + 2)
        items.append(f"{prefix}  {key_str}: {val_str}")
    return "{\n" + ",\n".join(items) + f"\n{prefix}}}"


def colorize_list(lst: list, indent: int = 0) -> str:
    """Colorize a JSON array."""
    if not lst:
        return "[]"
    prefix = " " * indent
    items = []
    for v in lst:
        items.append(f"{prefix}  {colorize_json_value(v, indent + 2)}")
    return "[\n" + ",\n".join(items) + f"\n{prefix}]"


def pretty_print_json(data: Any, sort_keys: bool = False, color: bool = True) -> str:
    """Pretty print JSON with optional color."""
    if color:
        return colorize_json_value(data)
    else:
        return json.dumps(data, indent=2, sort_keys=sort_keys)


def validate_json(content: str) -> tuple[bool, Optional[json.JSONDecodeError]]:
    """Validate JSON string and return (is_valid, error)."""
    try:
        json.loads(content)
        return True, None
    except json.JSONDecodeError as e:
        return False, e


def main():
    parser = argparse.ArgumentParser(
        description="Pretty-print and validate JSON files with color output.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  json-formatter config.json
  json-formatter data.json --sort-keys
  json-formatter data.json --minify
  json-formatter data.json --validate
  cat file.json | json-formatter -
        """
    )
    parser.add_argument('file', nargs='?', default='-', help='JSON file to format (use - for stdin)')
    parser.add_argument('--minify', '-m', action='store_true', help='Minify output instead of pretty-print')
    parser.add_argument('--sort-keys', '-s', action='store_true', help='Sort dictionary keys alphabetically')
    parser.add_argument('--validate', '-v', action='store_true', help='Only validate, do not output')
    parser.add_argument('--no-color', '-nc', action='store_true', help='Disable color output')
    parser.add_argument('--indent', '-i', type=int, default=2, help='Indentation level (default: 2)')

    args = parser.parse_args()

    # Read input
    try:
        if args.file == '-':
            content = sys.stdin.read()
        else:
            path = Path(args.file)
            if not path.exists():
                print(f"Error: File not found: {args.file}", file=sys.stderr)
                sys.exit(2)
            content = path.read_text(encoding='utf-8')
    except Exception as e:
        print(f"Error reading file: {e}", file=sys.stderr)
        sys.exit(2)

    # Validate first
    is_valid, error = validate_json(content)
    if not is_valid:
        print(f"❌ Invalid JSON: {error.msg}", file=sys.stderr)
        print(f"   Position: line {error.lineno}, column {error.colno}", file=sys.stderr)
        print(f"   Context: {error.doc[max(0, error.pos-20):error.pos+20]}", file=sys.stderr)
        sys.exit(1)

    if args.validate:
        print(f"✅ Valid JSON{'' if not args.file or args.file == '-' else ' in ' + args.file}")
        sys.exit(0)

    # Parse and output
    try:
        data = json.loads(content)

        if args.minify:
            output = json.dumps(data, sort_keys=args.sort_keys, separators=(',', ':'))
            print(output)
        else:
            output = json.dumps(data, indent=args.indent, sort_keys=args.sort_keys, ensure_ascii=False)
            if not args.no_color:
                # For colored output, use our custom colorizer
                print(colorize_json_value(data))
            else:
                print(output)

    except json.JSONDecodeError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)
    except Exception as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == '__main__':
    main()
