#!/usr/bin/env python3
"""
Env Validator - Validate .env files for common issues.
Checks for: missing required vars, invalid formats, debug flags in production,
exposed secrets, and common misconfigurations.

Usage: env-validator [.env file] [--schema schema.env] [--strict] [--prod]
"""

import argparse
import os
import re
import sys
from pathlib import Path
from typing import Dict, List, Optional, Set, Tuple

# ANSI color codes
RED = '\033[91m'
GREEN = '\033[92m'
YELLOW = '\033[93m'
BLUE = '\033[94m'
BOLD = '\033[1m'
RESET = '\033[0m'

try:
    from termcolor import colored
    HAS_TERMCOLOR = True
except ImportError:
    HAS_TERMCOLOR = False


def color_error(msg):
    if HAS_TERMCOLOR:
        return colored(msg, 'red', attrs=['bold'])
    return f"[ERROR] {msg}"


def color_warning(msg):
    if HAS_TERMCOLOR:
        return colored(msg, 'yellow', attrs=['bold'])
    return f"[WARN] {msg}"


def color_success(msg):
    if HAS_TERMCOLOR:
        return colored(msg, 'green')
    return msg


def color_info(msg):
    if HAS_TERMCOLOR:
        return colored(msg, 'blue')
    return msg


# Patterns for common issues
DEBUG_PATTERNS = [
    (re.compile(r'^\s*DEBUG\s*=\s*(true|1|yes|on)\s*$', re.IGNORECASE), "DEBUG flag is ON"),
    (re.compile(r'^\s*LOG_LEVEL\s*=\s*(debug|trace|verbose)\s*$', re.IGNORECASE), "Verbose logging enabled"),
    (re.compile(r'^\s*VERBOSE\s*=\s*(true|1|yes)\s*$', re.IGNORECASE), "VERBOSE flag is ON"),
]

SECRET_PATTERNS = [
    (re.compile(r'^\s*(PRIVATE_KEY|SECRET_KEY|API_KEY|ACCESS_TOKEN|SESSION_SECRET)\s*=\s*(.+\S)?\s*$', re.IGNORECASE), "Secret key detected"),
    (re.compile(r'^\s*PASSWORD\s*=\s*(.+\S)?\s*$', re.IGNORECASE), "Password detected"),
    (re.compile(r'^\s*(AWS_|AZURE_|GCP_|STRIPE_)(SECRET|KEY)\s*=\s*(.+\S)?\s*$', re.IGNORECASE), "Cloud secret detected"),
    (re.compile(r'^\s*DATABASE_URL\s*=\s*.*\b(password|pwd)=([^;&]+)\b', re.IGNORECASE), "Database password in URL"),
]

VALIDATION_RULES = [
    # URL patterns
    (re.compile(r'^\s*(DATABASE_URL|REDIS_URL|AMQP_URL|MESSAGE_QUEUE_URL)\s*=\s*(.+\S)?\s*$', re.IGNORECASE), 
     lambda v: (not v or not v.startswith(('postgres://', 'mysql://', 'redis://', 'amqp://', 'mongodb://', 'sqlite://')), "URL should use postgres://, mysql://, redis://, amqp://, or mongodb://")),
    
    # Email format
    (re.compile(r'^\s*(ADMIN_EMAIL|SERVER_EMAIL|FROM_EMAIL)\s*=\s*(.+\S)?\s*$', re.IGNORECASE),
     lambda v: (not v or not re.match(r'^[\w\.-]+@[\w\.-]+\.\w+$', v), "Invalid email format")),
    
    # Port numbers
    (re.compile(r'^\s*(PORT|DB_PORT|REDIS_PORT)\s*=\s*(\d+)\s*$', re.IGNORECASE),
     lambda v: (not (1 <= int(v) <= 65535), "Port should be between 1 and 65535")),
]

PROD_ONLY_VARS = [
    'DEBUG', 'LOG_LEVEL', 'VERBOSE', 'DEV_MODE', 'DEVELOPMENT',
    'CACHE_ENABLED', 'ENABLE_DEBUG', 'DISABLE_CACHE',
]

PROD_MUST_HAVE = [
    'NODE_ENV', 'APP_ENV', 'ENV',
]


class ValidationIssue:
    def __init__(self, severity: str, key: str, message: str, line: int = 0):
        self.severity = severity  # error, warning, info
        self.key = key
        self.message = message
        self.line = line
    
    def __str__(self):
        icon = {'error': '🔴', 'warning': '🟡', 'info': '🔵'}.get(self.severity, '⚪')
        loc = f" line {self.line}" if self.line else ""
        return f"{icon} [{self.severity.upper()}] {self.key or '(global)'}: {self.message}{loc}"


def parse_env_file(path: str) -> Tuple[Dict[str, str], List[Tuple[int, str]]]:
    """Parse .env file, return dict of key->value and list of (line_num, raw_line)."""
    env_vars = {}
    raw_lines = []
    
    try:
        with open(path, 'r') as f:
            for line_num, line in enumerate(f, 1):
                raw_lines.append((line_num, line))
                line = line.strip()
                
                # Skip empty lines and comments
                if not line or line.startswith('#'):
                    continue
                
                # Parse KEY=VALUE
                if '=' in line:
                    key, _, value = line.partition('=')
                    key = key.strip()
                    value = value.strip().strip('"').strip("'")
                    if key:
                        env_vars[key] = value
    except FileNotFoundError:
        print(color_error(f"File not found: {path}"), file=sys.stderr)
        sys.exit(1)
    except PermissionError:
        print(color_error(f"Permission denied: {path}"), file=sys.stderr)
        sys.exit(1)
    
    return env_vars, raw_lines


def validate_env(env_vars: Dict[str, str], raw_lines: List[Tuple[int, str]], 
                 schema: Optional[Dict[str, str]] = None,
                 strict: bool = False,
                 is_prod: bool = False) -> List[ValidationIssue]:
    """Validate .env content and return list of issues."""
    issues = []
    found_keys = set(env_vars.keys())
    
    # Check for debug/verbose flags
    for line_num, line in raw_lines:
        for pattern, msg in DEBUG_PATTERNS:
            if pattern.match(line):
                issues.append(ValidationIssue('warning', '', msg, line_num))
    
    # Check for exposed secrets
    for line_num, line in raw_lines:
        for pattern, msg in SECRET_PATTERNS:
            if pattern.match(line):
                issues.append(ValidationIssue('error', '', msg, line_num))
    
    # Check URL formats
    for line_num, line in raw_lines:
        for pattern, validator in VALIDATION_RULES:
            match = pattern.match(line)
            if match:
                value = match.group(2) if match.lastindex >= 2 else ''
                is_invalid, err_msg = validator(value)
                if is_invalid:
                    issues.append(ValidationIssue('warning', '', err_msg, line_num))
    
    # Check for placeholder values
    placeholder_patterns = [
        re.compile(r'^\s*\w+\s*=\s*(your-|my-|<|>|\$\{|example|todo|tbd|change_me|xxxxx)\S*\s*$', re.IGNORECASE),
    ]
    for line_num, line in raw_lines:
        for pattern in placeholder_patterns:
            if pattern.match(line):
                key = line.split('=')[0].strip()
                issues.append(ValidationIssue('warning', key, "Contains placeholder value", line_num))
    
    # Production checks
    if is_prod:
        # Check debug flags
        for key in PROD_ONLY_VARS:
            if key.upper() in found_keys:
                val = env_vars.get(key.upper(), '')
                if val.lower() in ('true', '1', 'yes', 'on', 'debug'):
                    issues.append(ValidationIssue('error', key, 
                        f"{key} should not be enabled in production", 
                        next((ln for ln, l in raw_lines if l.strip().startswith(f"{key}=")), 0)))
        
        # Check for missing required production vars
        for req in PROD_MUST_HAVE:
            if req not in found_keys:
                issues.append(ValidationIssue('info', req, 
                    f"Consider defining {req} for production environments"))
    
    # Schema validation
    if schema:
        missing = set(schema.keys()) - found_keys
        for key in missing:
            issues.append(ValidationIssue('warning', key, "Missing from .env (defined in schema)"))
        
        if strict:
            extra = found_keys - set(schema.keys())
            for key in extra:
                if key.isupper() and not key.startswith('#'):
                    issues.append(ValidationIssue('info', key, "Not in schema (extra)"))
    
    # Check for duplicate keys (last one wins)
    seen_keys = set()
    for line_num, line in raw_lines:
        if '=' in line:
            key = line.split('=')[0].strip()
            if key in seen_keys:
                issues.append(ValidationIssue('warning', key, "Duplicate key (last value wins)", line_num))
            seen_keys.add(key)
    
    return issues


def print_report(issues: List[ValidationIssue], filename: str, show_info: bool = True):
    """Print validation report."""
    errors = [i for i in issues if i.severity == 'error']
    warnings = [i for i in issues if i.severity == 'warning']
    infos = [i for i in issues if i.severity == 'info' and show_info]
    
    print(f"\n{'='*60}")
    print(f"📋 ENV VALIDATOR REPORT: {filename}")
    print(f"{'='*60}")
    
    if not issues:
        print(color_success("\n✅ No issues found!"))
        return
    
    print(f"\n🔴 Errors:   {len(errors)}")
    print(f"🟡 Warnings: {len(warnings)}")
    if show_info:
        print(f"🔵 Info:     {len(infos)}")
    
    if errors:
        print(f"\n{RED}{BOLD}ERRORS (must fix):{RESET}")
        for issue in errors:
            print(f"  {issue}")
    
    if warnings:
        print(f"\n{YELLOW}{BOLD}WARNINGS (should fix):{RESET}")
        for issue in warnings:
            print(f"  {issue}")
    
    if infos and show_info:
        print(f"\n{BLUE}INFO (suggestions):{RESET}")
        for issue in infos:
            print(f"  {issue}")
    
    print(f"\n{'='*60}")
    if errors:
        print(color_error(f"❌ FAILED: {len(errors)} error(s) found"))
        return 1
    elif warnings:
        print(color_warning(f"⚠️  PASSED WITH WARNINGS: {len(warnings)} warning(s)"))
        return 0
    else:
        print(color_success(f"✅ PASSED: {len(infos)} info(s)"))
        return 0


def main():
    parser = argparse.ArgumentParser(
        description="Validate .env files for common issues and misconfigurations.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  env-validator .env
  env-validator .env --prod
  env-validator .env --schema .env.example --strict
  env-validator .env -q  # quiet, only exit code
        """
    )
    parser.add_argument('file', nargs='?', default='.env',
                        help='.env file to validate (default: .env)')
    parser.add_argument('-s', '--schema', 
                        help='Reference .env file (schema) to check for missing keys')
    parser.add_argument('--strict', action='store_true',
                        help='Warn about extra keys not in schema')
    parser.add_argument('-p', '--prod', action='store_true',
                        help='Enable production-specific checks (DEBUG must be off, etc.)')
    parser.add_argument('-q', '--quiet', action='store_true',
                        help='Only print summary, no info-level messages')
    parser.add_argument('-v', '--version', action='store_true',
                        help='Show version')
    
    args = parser.parse_args()
    
    if args.version:
        print("env-validator v1.0")
        sys.exit(0)
    
    env_path = args.file
    schema_path = args.schema
    is_prod = args.prod
    show_info = not args.quiet
    
    # Parse schema if provided
    schema = None
    if schema_path:
        schema, _ = parse_env_file(schema_path)
    
    # Parse and validate
    env_vars, raw_lines = parse_env_file(env_path)
    issues = validate_env(env_vars, raw_lines, schema=schema, 
                         strict=args.strict, is_prod=is_prod)
    
    exit_code = print_report(issues, env_path, show_info=show_info)
    sys.exit(0 if exit_code == 0 else 1)


if __name__ == '__main__':
    main()
