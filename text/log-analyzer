#!/usr/bin/env python3
"""
Log Analyzer - Parse log files and summarize errors, warnings, and statistics.
Usage: log-analyzer <log_file> [--errors] [--warnings] [--info] [--pattern regex]
"""

import argparse
import re
import sys
from collections import Counter, defaultdict
from datetime import datetime
from pathlib import Path
from typing import List, Tuple, Optional


# Common log level patterns
LOG_LEVELS = {
    'ERROR': r'\b(ERROR|ERR|SEVERE|FATAL|CRITICAL|CRIT)\b',
    'WARNING': r'\b(WARN|WARNING|CAUTION)\b',
    'INFO': r'\b(INFO|NOTICE)\b',
    'DEBUG': r'\b(DEBUG|DBG|TRACE|VERBOSE)\b',
}


class LogAnalyzer:
    def __init__(self, file_path: str):
        self.file_path = Path(file_path)
        self.lines: List[str] = []
        self.errors: List[Tuple[int, str]] = []
        self.warnings: List[Tuple[int, str]] = []
        self.info: List[Tuple[int, str]] = []
        self.debug: List[Tuple[int, str]] = []
        self.pattern_matches: List[Tuple[int, str]] = []
        self.custom_pattern: Optional[str] = None
        self.timestamp_pattern = re.compile(
            r'[\d]{4}[-/]\d{2}[-/]\d{2}[T\s]\d{2}:\d{2}:\d{2}'
        )
        
    def load(self) -> bool:
        """Load log file into memory."""
        try:
            with open(self.file_path, 'r', encoding='utf-8', errors='replace') as f:
                self.lines = f.readlines()
            return True
        except Exception as e:
            print(f"Error loading log file: {e}", file=sys.stderr)
            return False
    
    def analyze(self, show_errors: bool = True, show_warnings: bool = True,
               show_info: bool = False, show_debug: bool = False,
               custom_pattern: Optional[str] = None):
        """Analyze log file for different log levels."""
        self.custom_pattern = custom_pattern
        
        for i, line in enumerate(self.lines, 1):
            line_stripped = line.strip()
            if not line_stripped:
                continue
            
            # Check custom pattern first
            if custom_pattern:
                if re.search(custom_pattern, line, re.IGNORECASE):
                    self.pattern_matches.append((i, line_stripped))
                    continue  # Don't double-count
            
            # Check log levels
            if show_errors and re.search(LOG_LEVELS['ERROR'], line, re.IGNORECASE):
                self.errors.append((i, line_stripped))
            elif show_warnings and re.search(LOG_LEVELS['WARNING'], line, re.IGNORECASE):
                self.warnings.append((i, line_stripped))
            elif show_info and re.search(LOG_LEVELS['INFO'], line, re.IGNORECASE):
                self.info.append((i, line_stripped))
            elif show_debug and re.search(LOG_LEVELS['DEBUG'], line, re.IGNORECASE):
                self.debug.append((i, line_stripped))
    
    def get_summary(self) -> dict:
        """Get summary statistics."""
        return {
            'total_lines': len(self.lines),
            'errors': len(self.errors),
            'warnings': len(self.warnings),
            'info': len(self.info),
            'debug': len(self.debug),
            'pattern_matches': len(self.pattern_matches),
        }
    
    def get_error_context(self, error_idx: int, context_lines: int = 2) -> List[Tuple[int, str]]:
        """Get surrounding context for an error."""
        if error_idx >= len(self.errors):
            return []
        
        line_num = self.errors[error_idx][0]
        start = max(0, line_num - context_lines - 1)
        end = min(len(self.lines), line_num + context_lines)
        
        return [(i+1, self.lines[i].rstrip()) for i in range(start, end)]
    
    def find_common_patterns(self, entries: List[Tuple[int, str]]) -> Counter:
        """Find common error/warning patterns."""
        # Extract just the message part (remove line numbers and timestamps)
        patterns = []
        for _, line in entries:
            # Try to extract meaningful message pattern
            msg = re.sub(r'\d{4}[-/]\d{2}[-/]\d{2}[T\s]\d{2}:\d{2}:\d{2}[^\s]*\s*', '', line)
            msg = re.sub(r'(ERROR|WARN|INFO|DEBUG|CRITICAL|FATAL):?\s*', '', msg, flags=re.IGNORECASE)
            msg = re.sub(r'\[(?:pid|tid|thread)\s*\d+\]', '', msg, flags=re.IGNORECASE)
            msg = msg.strip()
            if msg:
                # Truncate for grouping
                patterns.append(msg[:100])
        return Counter(patterns)
    
    def print_summary(self):
        """Print formatted summary."""
        summary = self.get_summary()
        
        print("\n" + "="*60)
        print("📊 LOG ANALYZER SUMMARY")
        print("="*60)
        print(f"\n📁 File: {self.file_path}")
        print(f"📄 Total lines: {summary['total_lines']:,}")
        
        print("\n" + "-"*40)
        print("🔴 ERRORS:   ", summary['errors'])
        print("🟡 WARNINGS: ", summary['warnings'])
        print("🔵 INFO:     ", summary['info'])
        print("🔵 DEBUG:    ", summary['debug'])
        if self.custom_pattern:
            print(f"🔍 PATTERN:   {summary['pattern_matches']}")
        print("-"*40)
        
        # Percentage bar
        if summary['total_lines'] > 0:
            total_issues = summary['errors'] + summary['warnings']
            pct = (total_issues / summary['total_lines']) * 100
            bar_len = 30
            filled = int((total_issues / max(summary['total_lines'], 1)) * bar_len)
            bar = "█" * filled + "░" * (bar_len - filled)
            print(f"\n📈 Issue density: [{bar}] {pct:.1f}%")
    
    def print_top_errors(self, n: int = 10):
        """Print most common error patterns."""
        if not self.errors:
            return
        
        print("\n" + "="*60)
        print("🔴 TOP ERROR PATTERNS")
        print("="*60)
        
        patterns = self.find_common_patterns(self.errors)
        for msg, count in patterns.most_common(n):
            print(f"  [{count:>3}x] {msg[:80]}")
    
    def print_top_warnings(self, n: int = 10):
        """Print most common warning patterns."""
        if not self.warnings:
            return
        
        print("\n" + "="*60)
        print("🟡 TOP WARNING PATTERNS")
        print("="*60)
        
        patterns = self.find_common_patterns(self.warnings)
        for msg, count in patterns.most_common(n):
            print(f"  [{count:>3}x] {msg[:80]}")
    
    def print_entries(self, entries: List[Tuple[int, str]], title: str, n: int = 20):
        """Print log entries."""
        if not entries:
            return
        
        print(f"\n{'='*60}")
        print(title)
        print("="*60)
        
        for i, (line_num, line) in enumerate(entries[:n]):
            print(f"{line_num:>6}: {line[:120]}")
        
        if len(entries) > n:
            print(f"\n  ... and {len(entries) - n} more entries")
    
    def print_timeline(self, bins: int = 10):
        """Show rough timeline distribution of errors/warnings."""
        if not self.errors and not self.warnings:
            return
        
        print("\n" + "="*60)
        print("📈 ERROR/WARNING DISTRIBUTION")
        print("="*60)
        
        # Find timestamps
        timestamps = []
        for i, line in enumerate(self.lines):
            match = self.timestamp_pattern.search(line)
            if match:
                try:
                    ts_str = match.group()
                    for fmt in ['%Y-%m-%d %H:%M:%S', '%Y/%m/%d %H:%M:%S', '%Y-%m-%dT%H:%M:%S']:
                        try:
                            ts = datetime.strptime(ts_str, fmt)
                            timestamps.append((i, ts))
                            break
                        except ValueError:
                            continue
                except:
                    pass
        
        if len(timestamps) < 2:
            print("  (Not enough timestamps for timeline)")
            return
        
        start_line = timestamps[0][0]
        end_line = timestamps[-1][0]
        line_range = max(end_line - start_line, 1)
        
        # Bin the errors/warnings
        error_bins = [0] * bins
        warn_bins = [0] * bins
        
        for line_num, _ in self.errors:
            bin_idx = min(int((line_num - start_line) / line_range * bins), bins - 1)
            error_bins[bin_idx] += 1
        
        for line_num, _ in self.warnings:
            bin_idx = min(int((line_num - start_line) / line_range * bins), bins - 1)
            warn_bins[bin_idx] += 1
        
        max_val = max(max(error_bins), max(warn_bins), 1)
        
        print("\n  Line distribution across file:")
        for i in range(bins):
            e_bar = "█" * int(error_bins[i] / max_val * 15) if max_val > 0 else ""
            w_bar = "▓" * int(warn_bins[i] / max_val * 15) if max_val > 0 else ""
            pct_start = int(i / bins * 100)
            pct_end = int((i+1) / bins * 100)
            print(f"  [{pct_start:>3}-{pct_end:>3}%] E:{e_bar:<15} W:{w_bar:<15}")
        
        print("                 E=Errors  W=Warnings")


def main():
    parser = argparse.ArgumentParser(
        description="Analyze log files and summarize errors, warnings, and statistics.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  log-analyzer app.log
  log-analyzer /var/log/syslog --errors --warnings
  log-analyzer error.log --top-errors 20
  log-analyzer server.log --pattern "timeout|connection"
  log-analyzer app.log -e 5 -w 5 --timeline
        """
    )
    parser.add_argument('log_file', help='Path to log file to analyze')
    parser.add_argument('-e', '--errors', action='store_true', help='Show error entries')
    parser.add_argument('-w', '--warnings', action='store_true', help='Show warning entries')
    parser.add_argument('-i', '--info', action='store_true', help='Show info entries')
    parser.add_argument('-d', '--debug', action='store_true', help='Show debug entries')
    parser.add_argument('-p', '--pattern', type=str, help='Custom regex pattern to search')
    parser.add_argument('-t', '--top-errors', type=int, default=10, metavar='N',
                       help='Show top N error patterns (default: 10)')
    parser.add_argument('--top-warnings', type=int, default=10, metavar='N',
                       help='Show top N warning patterns (default: 10)')
    parser.add_argument('--timeline', action='store_true', help='Show error/warning timeline')
    parser.add_argument('-n', '--lines', type=int, default=20, metavar='N',
                       help='Max entries to show per category (default: 20)')
    parser.add_argument('-q', '--quiet', action='store_true', help='Only show summary')
    
    args = parser.parse_args()
    
    # Default: show errors and warnings if nothing specified
    show_errors = args.errors or not (args.warnings or args.info or args.debug)
    show_warnings = args.warnings or not (args.errors or args.info or args.debug)
    show_info = args.info
    show_debug = args.debug
    
    analyzer = LogAnalyzer(args.log_file)
    
    if not analyzer.load():
        sys.exit(1)
    
    analyzer.analyze(
        show_errors=show_errors,
        show_warnings=show_warnings,
        show_info=show_info,
        show_debug=show_debug,
        custom_pattern=args.pattern
    )
    
    # Output
    if args.quiet:
        summary = analyzer.get_summary()
        print(f"errors={summary['errors']} warnings={summary['warnings']} "
              f"info={summary['info']} total={summary['total_lines']}")
    else:
        analyzer.print_summary()
        
        if analyzer.errors:
            analyzer.print_top_errors(n=args.top_errors)
        
        if analyzer.warnings:
            analyzer.print_top_warnings(n=args.top_warnings)
        
        if args.timeline:
            analyzer.print_timeline()
        
        if args.errors and analyzer.errors:
            analyzer.print_entries(analyzer.errors, "🔴 ERROR ENTRIES", n=args.lines)
        
        if args.warnings and analyzer.warnings:
            analyzer.print_entries(analyzer.warnings, "🟡 WARNING ENTRIES", n=args.lines)
        
        if args.info and analyzer.info:
            analyzer.print_entries(analyzer.info, "🔵 INFO ENTRIES", n=args.lines)
        
        if args.pattern and analyzer.pattern_matches:
            analyzer.print_entries(analyzer.pattern_matches, f"🔍 PATTERN MATCHES: {args.pattern}", 
                                   n=args.lines)
        
        print()


if __name__ == '__main__':
    main()
